{
  "name": "mejora",
  "version": "3.2.1",
  "description": "Prevent regressions. Allow improvement.",
  "keywords": [
    "regression",
    "baseline",
    "ci",
    "continuous-integration",
    "linting",
    "eslint",
    "typescript",
    "quality",
    "code-quality",
    "developer-tools",
    "cli",
    "testing",
    "incremental",
    "legacy-code"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jimmy-guzman/mejora.git"
  },
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "mejora": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "check": "pnpm lint && pnpm typecheck && pnpm coverage && pnpm format && pnpm knip",
    "coverage": "vitest run --coverage",
    "dev": "tsdown --watch",
    "format": "prettier --check --cache --experimental-cli .",
    "format:fix": "prettier --write --cache --experimental-cli .",
    "knip": "knip",
    "lint": "eslint --cache --cache-location node_modules/.cache/eslint .",
    "lint:fix": "pnpm lint --fix",
    "prepack": "pnpm build && clean-pkg-json",
    "prepare": "lefthook install",
    "test": "vitest",
    "typecheck": "tsc"
  },
  "prettier": "@jimmy.codes/prettier-config",
  "devDependencies": {
    "@commitlint/config-conventional": "21.2.0",
    "@jimmy.codes/eslint-config": "9.0.0",
    "@jimmy.codes/prettier-config": "2.1.2",
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "clean-pkg-json": "2.0.0",
    "commitlint": "21.2.1",
    "eslint": "10.6.0",
    "gitzy": "7.2.2",
    "knip": "6.26.0",
    "lefthook": "2.1.10",
    "lilconfig": "3.1.3",
    "pathe": "2.0.3",
    "prettier": "3.9.5",
    "publint": "0.3.21",
    "tsdown": "0.22.4",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "peerDependencies": {
    "eslint": "^9.34.0",
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">= 22.18.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "gitzy": {
    "useCommitlintConfig": true
  }
}
